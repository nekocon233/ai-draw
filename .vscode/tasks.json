{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "deploy: remote",
      "detail": "Rebuilds and starts the project through the remote Docker Engine.",
      "dependsOrder": "sequence",
      "dependsOn": [
        "stop: remote",
        "clean: frontend volume",
        "build: remote",
        "up: remote"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "deploy: remote (no cache)",
      "detail": "Rebuilds without cache and starts the project through the remote Docker Engine.",
      "dependsOrder": "sequence",
      "dependsOn": [
        "stop: remote",
        "clean: frontend volume",
        "build: remote (no cache)",
        "up: remote"
      ],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "clean: frontend volume",
      "detail": "Removes stale frontend assets before rebuilding the project.",
      "hide": true,
      "type": "process",
      "command": "docker",
      "args": [
        "volume",
        "rm",
        "--force",
        "ai-draw_frontend-dist"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "build: remote",
      "detail": "Builds project images on the remote Docker Engine.",
      "hide": true,
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "build: remote (no cache)",
      "detail": "Builds project images without cache on the remote Docker Engine.",
      "hide": true,
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "build",
        "--no-cache"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "up: remote",
      "detail": "Starts project services on the remote Docker Engine.",
      "hide": true,
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "status: remote",
      "detail": "Shows project service status from the remote Docker Engine.",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "ps"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "logs: remote",
      "detail": "Follows project logs from the remote Docker Engine.",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "logs",
        "-f",
        "--tail=200"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "stop: remote",
      "detail": "Stops project services on the remote Docker Engine.",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "restart: remote",
      "detail": "Restarts project services on the remote Docker Engine.",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "restart"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_HOST": "ssh://nekocon-server"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "close": true
      }
    }
  ]
}
