    {
      "label": "首次部署（构建并启动）",
      "type": "shell",
      "command": "docker compose build --no-cache && docker compose up -d",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
