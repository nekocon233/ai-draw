# ai-draw environment configuration example

# Application
TZ=Asia/Shanghai
APP_NAME=ai-draw
APP_DEBUG=true
APP_VERSION=1.0.0

# Server and frontend ports
SERVER_HOST=0.0.0.0
SERVER_PORT=14600
SERVER_RELOAD=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:14601","https://your-production-domain.com"]
FRONTEND_HTTP_PORT=14601
FRONTEND_HTTPS_PORT=14602

# ComfyUI
COMFYUI_ENABLED=true
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188
COMFYUI_PATH=
COMFYUI_PYTHON=
COMFYUI_TIMEOUT=30
COMFYUI_CHECK_INTERVAL=5000
COMFYUI_CLOUD_ENABLED=false
COMFYUI_CLOUD_API_URL=

# AI Prompt
AI_PROMPT_PROVIDER=openai
AI_PROMPT_API_KEY=your-api-key-here
AI_PROMPT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
AI_PROMPT_MODEL=glm-4.7
AI_PROMPT_TEMPLATE="你是一个Stable Diffusion提示词专家，请将以下自然语言描述转换为SD提示词（英文标签，用逗号分隔，不要增加额外的描述）：\n描述：{desc}\n只输出提示词，不要解释："
AI_PROMPT_REUSE_SESSION_TITLE=true

# Session title generation
SESSION_TITLE_API_KEY=your-session-title-api-key-here
SESSION_TITLE_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
SESSION_TITLE_MODEL=glm-4.7

# Nano Banana Pro / Gemini
NANO_BANANA_API_KEY=your-nano-banana-api-key-here
NANO_BANANA_BASE_URL=https://api.uniapi.io/gemini
NANO_BANANA_MODEL=gemini-3-pro-image-preview
NANO_BANANA_ANALYSIS_MODEL=gemini-3.1-flash-image-preview

# PixelLab
PIXEL_LAB_API_KEY=

# GPT Image
GPT_IMAGE_API_KEY=your-gpt-image-api-key-here
GPT_IMAGE_BASE_URL=https://api.uniapi.io/v1
GPT_IMAGE_MODEL=gpt-image-2-all

# Kling video
KLING_API_KEY=your-kling-api-key-here
KLING_BASE_URL=https://api.uniapi.io/kling
KLING_MODEL=kling-v3

# Video frame extraction and background removal
VIDEO_BACKGROUND_MODE=inspyrenet
REMBG_MODEL=isnet-anime
SPRITESHEET_MAX_FRAMES=64
REMBG_ALPHA_MATTING=true
REMBG_ALPHA_FG_THRESHOLD=240
REMBG_ALPHA_BG_THRESHOLD=10
REMBG_ALPHA_ERODE_SIZE=10
REMBG_POST_PROCESS_MASK=true
INSPYRENET_MODE=base
INSPYRENET_RESIZE=static
BIREFNET_MODEL=ZhengPeng7/BiRefNet
BIREFNET_IMAGE_SIZE=1024
BIREFNET_DEVICE=auto
BIREFNET_PRECISION=auto
VIDEO_EDGE_THRESHOLD=32
VIDEO_EDGE_FEATHER=10

# Image upscale models and limits
UPSCALE_GENERAL_MODEL=RealESRGAN_x4plus.pth
UPSCALE_ANIME_MODEL=RealESRGAN_x4plus_anime_6B.pth
UPSCALE_REALESRGAN_2X_MODEL=RealESRGAN_x2plus.pth
UPSCALE_APISR_2X_MODEL=2x_APISR_RRDB_GAN_generator.pth
UPSCALE_APISR_4X_MODEL=4x_APISR_DAT_GAN_generator.pth
UPSCALE_REAL_CUGAN_2X_MODEL=pro-no-denoise-up2x.pth
UPSCALE_REAL_CUGAN_4X_MODEL=up4x-latest-conservative.pth
UPSCALE_INVSR_SD_MODEL=stabilityai/sd-turbo
UPSCALE_INVSR_MODEL=noise_predictor_sd_turbo_v5.pth
UPSCALE_INVSR_DTYPE=fp16
UPSCALE_INVSR_CHOPPING_SIZE=128
UPSCALE_GENERAL_NATIVE_SCALE=4
UPSCALE_ANIME_NATIVE_SCALE=4
UPSCALE_MAX_EDGE=4096
UPSCALE_MAX_PIXELS=16777216
UPSCALE_MAX_INPUT_BYTES=52428800

# Authentication
# Generate secrets with: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
INVITE_CODE=your-invite-code-here

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_draw
DB_USER=ai_draw
DB_PASSWORD=your-secure-password-here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Paths relative to the application root
WORKFLOWS_PATH=configs/workflows
UPLOAD_DIR=uploads/
