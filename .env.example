# AI-Draw 环境变量配置示例

# AI Prompt API 密钥
AI_PROMPT_API_KEY=your-api-key-here

# JWT 认证密钥
# 生成方法: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-here

# 注册邀请码（用户注册时需提供）
INVITE_CODE=your-invite-code-here

# 数据库密码
# 生成方法: openssl rand -hex 32
DB_PASSWORD=your-secure-password-here

# Redis 密码（可选，留空表示无密码）
# 生成方法: openssl rand -hex 32
REDIS_PASSWORD=

# 生产环境域名（用于 CORS 配置）
PRODUCTION_DOMAIN=https://your-production-domain.com

# 文件上传目录（相对于项目根目录）
UPLOAD_DIR=uploads/

# Nano Banana Pro / Gemini 配置
NANO_BANANA_API_KEY=your-nano-banana-api-key-here
# 第三方兼容 API Base URL（留空则使用官方 Google API）
NANO_BANANA_BASE_URL=https://api.uniapi.io/gemini
# 使用的 Gemini 模型名称
NANO_BANANA_MODEL=gemini-3-pro-image-preview
# PixelLab API 配置
PIXEL_LAB_API_KEY=your-pixel-lab-api-key-here
# GPT Image 2.0（OpenAI 兼容 API）配置
GPT_IMAGE_API_KEY=your-gpt-image-api-key-here
GPT_IMAGE_BASE_URL=https://api.uniapi.io/v1
GPT_IMAGE_MODEL=gpt-image-2-all
# Kling 视频生成（首尾帧图生视频）配置
KLING_API_KEY=your-kling-api-key-here
KLING_BASE_URL=https://api.uniapi.io/kling
KLING_MODEL=kling-v3

# 图片放大增强（文件名需与 ComfyUI models/upscale_models 一致）
UPSCALE_GENERAL_MODEL=RealESRGAN_x4plus.pth
UPSCALE_ANIME_MODEL=RealESRGAN_x4plus_anime_6B.pth
UPSCALE_REALESRGAN_2X_MODEL=RealESRGAN_x2plus.pth
UPSCALE_APISR_2X_MODEL=2x_APISR_RRDB_GAN_generator.pth
UPSCALE_APISR_4X_MODEL=4x_APISR_DAT_GAN_generator.pth
UPSCALE_REAL_CUGAN_2X_MODEL=pro-no-denoise-up2x.pth
UPSCALE_REAL_CUGAN_4X_MODEL=up4x-latest-conservative.pth
UPSCALE_GENERAL_NATIVE_SCALE=4
UPSCALE_ANIME_NATIVE_SCALE=4
UPSCALE_INVSR_SD_MODEL=stabilityai/sd-turbo
UPSCALE_INVSR_MODEL=noise_predictor_sd_turbo_v5.pth
UPSCALE_INVSR_DTYPE=fp16
UPSCALE_INVSR_CHOPPING_SIZE=128
# 浏览器画布安全限制
UPSCALE_MAX_EDGE=4096
UPSCALE_MAX_PIXELS=16777216
UPSCALE_MAX_INPUT_BYTES=52428800
