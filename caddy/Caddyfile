{
	auto_https off
	admin off
}

:80 {
	encode zstd gzip

	request_body {
		max_size 100MB
	}

	route {
		handle /health {
			header Content-Type text/plain
			respond "healthy" 200
		}

		@backend path /api/* /ws /ws/* /docs /docs/* /openapi.json
		handle @backend {
			reverse_proxy ai-draw-backend:{$BACKEND_PORT} {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 30s
				}
			}
		}

		@legacy_upscaled path_regexp legacy_upscaled ^/uploads/upscaled/(edited_upscaled_[^/]+\.png)$
		handle @legacy_upscaled {
			rewrite * /uploads/frames/edited/{re.legacy_upscaled.1}
			root * /srv
			header Cache-Control "public, max-age=604800"
			file_server
		}

		handle /uploads/upscaled/* {
			root * /srv
			header Cache-Control "no-store"
			file_server
		}

		handle /uploads/* {
			root * /srv
			header Cache-Control "public, max-age=604800"
			file_server
		}

		@static_assets path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2 *.ttf *.eot
		handle @static_assets {
			root * /srv/frontend
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		handle {
			root * /srv/frontend
			try_files {path} /index.html
			file_server
		}
	}
}
